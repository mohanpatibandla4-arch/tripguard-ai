# TripGuard AI — environment variables (copy to shell or .env)

# --- Email (SMTP) — Gmail, SendGrid SMTP, Mailtrap, etc. ---
# NOTIFICATION_EMAIL_ENABLED=true
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your@gmail.com
# SMTP_PASSWORD=your-app-password
# NOTIFICATION_EMAIL_FROM=TripGuard AI <your@gmail.com>

# --- SMS (Twilio) — https://www.twilio.com/console ---
# NOTIFICATION_SMS_ENABLED=true
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890

# --- Real-time flight polling (minutes between checks) ---
# FLIGHT_MONITOR_ENABLED=true
# FLIGHT_MONITOR_INTERVAL_MS=300000

# --- OpenAI chat ---
# OPENAI_API_KEY=sk-...
